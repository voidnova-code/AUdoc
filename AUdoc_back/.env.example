# ══════════════════════════════════════════════════════════════════════════════
# AUdoc Django Backend - Environment Configuration
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Security Settings ────────────────────────────────────────────────────────
# Secret key for cryptographic operations (generate a strong random key!)
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-super-secret-key-here

# Enable debug mode (NEVER use True in production!)
DJANGO_DEBUG=False

# Allowed hosts - comma separated (e.g., "example.com,www.example.com")
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins - comma separated (must include scheme)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Enable HTTPS redirect in production
DJANGO_SECURE_SSL_REDIRECT=False

# ── Email Configuration (Gmail) ──────────────────────────────────────────────
# For Gmail: enable 2-Step Verification and create an App Password at
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── AI Chatbot (Groq - Free Tier) ────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key
